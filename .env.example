# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hono_journal

# Auth
JWT_SECRET=replace-me-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=debug

# CORS (comma-separated list of origins; use * for any)
CORS_ORIGIN=http://localhost:3000
